# SafeContext — Environment variables
# Copy to .env and fill in values. Never commit .env.
# All secrets must come from environment — never hardcoded in code or images.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=safecontext
POSTGRES_USER=safecontext_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis (Broker + Cache) ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Adapter selector: "redis" (default) | future: "rabbitmq"
BROKER_ADAPTER=redis
CACHE_ADAPTER=redis

# ── Storage S3-compatible (Object Storage) ────────────────────────────────────
# StoragePort (ADR-011) abstrae el proveedor — swap = solo estas variables.
# Proveedor actual: MinIO CE pinned a RELEASE.2025-09-07 (ADR-013).
# Upgrade a AIStor: cambiar S3_ENDPOINT + credenciales, sin cambios de código.
#
# Formato de upgrade a AIStor:
#   S3_ENDPOINT=https://aisstor.internal:9000
#   S3_ACCESS_KEY=<aisstor_access_key>
#   S3_SECRET_KEY=<aisstor_secret_key>
#   STORAGE_ADAPTER=s3_compatible

S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_SECRET_KEY
S3_BUCKET_ARTIFACTS=safecontext-artifacts
S3_USE_SSL=false

# Adapter selector: "minio" (MinIO CE, default) | "s3_compatible" (AIStor, AWS S3, Garage, Ceph)
STORAGE_ADAPTER=minio

# ── OPA (Policy Engine) ───────────────────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_POLICY_PATH=/v1/data/safecontext

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
API_DEBUG=false
# Disable MFA enforcement in dev — dev users don't have TOTP configured.
# MUST be true (or removed entirely) in production.
API_REQUIRE_MFA=true

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_AUTH_TOKEN=CHANGE_ME_MCP_TOKEN

# ── Vault / OpenBao KMS (Transit engine) ──────────────────────────────────────
# Solo se levanta con --profile auth / --profile full. En dev usa el token raíz.
VAULT_ADDR=http://vault:8200
VAULT_DEV_TOKEN=safecontext-dev-token
# Nombre de la clave Transit (ECDSA-P256) para firmar evidencia. API y worker
# DEBEN usar el mismo valor o las firmas no verificarán entre sí.
VAULT_TRANSIT_KEY=safecontext-signing

# ── Audit trail — no-repudio (F7 / ADR-014) ───────────────────────────────────
# AUDIT_SIGN_ON_WRITE: firma + chain_hash al completar cada operación (write-time).
#   Déjalo en "true"; ponlo "false" solo en air-gapped sin Vault (solo chain_hash).
AUDIT_SIGN_ON_WRITE=true
# AUDIT_REQUIRE_DIGITAL_SIGNATURE: fail-closed (503) si el export no tiene firma
#   asimétrica. "true" obligatorio en producción; "false" en dev/tests.
AUDIT_REQUIRE_DIGITAL_SIGNATURE=false

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317
OTEL_SERVICE_NAME=safecontext-api

# ── Next.js UI ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://localhost/api
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=https://localhost

# ── Keycloak (OIDC) ───────────────────────────────────────────────────────────
# realm-safecontext.dev.json  → usuarios de prueba, sin MFA forzado (default dev)
# realm-safecontext.json      → sin usuarios, MFA forzado, URIs de producción
KEYCLOAK_REALM_FILE=realm-safecontext.dev.json

NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=safecontext
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=safecontext-ui
# Set to "true" in production to force MFA setup on first login.
# Leave unset (or "false") in development to skip TOTP for dev-* test users.
NEXT_PUBLIC_KEYCLOAK_FORCE_MFA=false
# Internal URL used by the Next.js server for token exchange (avoids localhost inside Docker).
# In docker-compose this is overridden to http://keycloak:8080 automatically.
# For local dev without Docker, leave unset (falls back to NEXT_PUBLIC_KEYCLOAK_URL).
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3

# ── Detector thresholds (overridden by OPA policy — these are fallback defaults)
DETECTOR_CONFIDENCE_THRESHOLD=0.85
