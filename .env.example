# SafeContext — Environment variables
# Copy to .env and fill in values. Never commit .env.
# All secrets must come from environment — never hardcoded in code or images.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=safecontext
POSTGRES_USER=safecontext_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis (Broker + Cache) ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Adapter selector: "redis" (default) | future: "rabbitmq"
BROKER_ADAPTER=redis
CACHE_ADAPTER=redis

# ── MinIO (Storage) ───────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY
MINIO_BUCKET_ARTIFACTS=safecontext-artifacts
MINIO_USE_SSL=false

# Adapter selector: "minio" (default, uses S3 API) | future: "s3", "aisstor"
STORAGE_ADAPTER=minio

# ── OPA (Policy Engine) ───────────────────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_POLICY_PATH=/v1/data/safecontext

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
API_DEBUG=false

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_AUTH_TOKEN=CHANGE_ME_MCP_TOKEN

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317
OTEL_SERVICE_NAME=safecontext-api

# ── Next.js UI ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://localhost/api
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=https://localhost

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3

# ── Detector thresholds (overridden by OPA policy — these are fallback defaults)
DETECTOR_CONFIDENCE_THRESHOLD=0.85
