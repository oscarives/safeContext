{
  "realm": "safecontext",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyPeriod": 30,
  "roles": {
    "realm": [
      {"name": "viewer", "description": "Read-only access to operations and findings"},
      {"name": "reviewer", "description": "Can approve or reject escalated findings"},
      {"name": "policy_editor", "description": "Can create and modify OPA policies"},
      {"name": "admin", "description": "Full access including user management"}
    ]
  },
  "clients": [
    {
      "clientId": "safecontext-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:8088/*", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:8088", "http://localhost:3000"]
    },
    {
      "clientId": "safecontext-ui",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8088/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8088",
        "http://localhost:3000"
      ],
      "protocolMappers": [
        {
          "name": "safecontext-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "safecontext-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "browserSecurityHeaders": {
    "xFrameOptions": "DENY",
    "contentSecurityPolicy": "frame-src 'none'; frame-ancestors 'none'; object-src 'none';"
  },
  "users": [
    {
      "username": "dev-viewer",
      "email": "dev-viewer@safecontext.dev",
      "firstName": "Dev",
      "lastName": "Viewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Dev1234!", "temporary": false}],
      "realmRoles": ["viewer"],
      "requiredActions": []
    },
    {
      "username": "dev-reviewer",
      "email": "dev-reviewer@safecontext.dev",
      "firstName": "Dev",
      "lastName": "Reviewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Dev1234!", "temporary": false}],
      "realmRoles": ["viewer", "reviewer"],
      "requiredActions": []
    },
    {
      "username": "dev-editor",
      "email": "dev-editor@safecontext.dev",
      "firstName": "Dev",
      "lastName": "Editor",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Dev1234!", "temporary": false}],
      "realmRoles": ["viewer", "policy_editor"],
      "requiredActions": []
    },
    {
      "username": "dev-admin",
      "email": "dev-admin@safecontext.dev",
      "firstName": "Dev",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "Dev1234!", "temporary": false}],
      "realmRoles": ["viewer", "reviewer", "policy_editor", "admin"],
      "requiredActions": []
    }
  ]
}
