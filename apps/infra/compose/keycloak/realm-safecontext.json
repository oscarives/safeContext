{
  "realm": "safecontext",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyPeriod": 30,
  "roles": {
    "realm": [
      {"name": "viewer", "description": "Read-only access to operations and findings"},
      {"name": "reviewer", "description": "Can approve or reject escalated findings"},
      {"name": "policy_editor", "description": "Can create and modify OPA policies"},
      {"name": "admin", "description": "Full access including user management"}
    ]
  },
  "clients": [
    {
      "clientId": "safecontext-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": ["https://safecontext.example.com/*"],
      "webOrigins": ["https://safecontext.example.com"]
    },
    {
      "clientId": "safecontext-ui",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://safecontext.example.com/*"],
      "webOrigins": ["https://safecontext.example.com"],
      "protocolMappers": [
        {
          "name": "safecontext-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "safecontext-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": true,
      "priority": 10
    }
  ],
  "browserSecurityHeaders": {
    "xFrameOptions": "DENY",
    "contentSecurityPolicy": "frame-src 'none'; frame-ancestors 'none'; object-src 'none';"
  }
}
