# Normalize line endings to LF in repo, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for these file types
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.rego text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.pdf binary
*.docx binary
*.tar binary
*.gz binary
